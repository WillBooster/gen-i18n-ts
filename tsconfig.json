{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "declaration": true,
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "undici-types": ["./node_modules/undici-types/index.d.ts"]
    },
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext",
    "types": ["node", "vitest/globals", "bun"]
  },
  "exclude": ["test/fixtures"],
  "extends": ["@tsconfig/bun/tsconfig.json", "@tsconfig/node-lts/tsconfig.json", "@tsconfig/node-ts/tsconfig.json"],
  "include": ["*.config.ts", "scripts/**/*", "src/**/*", "test/**/*", "vitest.config.ts"]
}
