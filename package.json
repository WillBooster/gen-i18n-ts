{
  "name": "gen-i18n-ts",
  "version": "0.0.0-semantically-released",
  "description": "A CLI tool to generate a strictly-typed i18n object literal written in TypeScript from JSON files.",
  "keywords": [
    "TypeScript",
    "i18n",
    "internationalization"
  ],
  "repository": "github:WillBooster/gen-i18n-ts",
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "bin": "./bin/index.cjs",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "build-ts app",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null && yarn lint-fix --quiet && yarn typecheck && yarn test --silent",
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn prettify",
    "postinstall": "husky || true",
    "lint": "eslint --color",
    "lint-fix": "yarn lint --fix",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "prepare": "husky || true",
    "prettify": "prettier --cache --color --write \"**/{.*/,}*.{cjs,css,cts,htm,html,js,json,json5,jsonc,jsx,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}\" \"!**/test-fixtures/**\"",
    "start": "build-ts run src/start.ts --",
    "start-prod": "yarn build && yarn gen-i18n-ts",
    "test": "yarn jest",
    "typecheck": "tsc --noEmit --Pretty"
  },
  "prettier": "@willbooster/prettier-config",
  "dependencies": {
    "js-yaml": "4.1.0",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@babel/core": "7.27.4",
    "@babel/helper-plugin-utils": "7.27.1",
    "@babel/node": "7.27.1",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-numeric-separator": "7.18.6",
    "@babel/preset-env": "7.27.2",
    "@babel/preset-typescript": "7.27.1",
    "@types/eslint": "8.56.11",
    "@types/jest": "29.5.14",
    "@types/js-yaml": "4.0.9",
    "@types/micromatch": "4.0.9",
    "@types/node": "22.15.29",
    "@types/yargs": "17.0.33",
    "@willbooster/babel-configs": "1.3.2",
    "@willbooster/eslint-config-ts": "11.2.0",
    "@willbooster/prettier-config": "10.0.0",
    "babel-jest": "29.7.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "build-ts": "13.2.3",
    "conventional-changelog-conventionalcommits": "9.0.0",
    "eslint": "9.28.0",
    "eslint-config-flat-gitignore": "2.1.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-import-resolver-typescript": "4.4.2",
    "eslint-plugin-import-x": "4.15.0",
    "eslint-plugin-sort-class-members": "1.21.0",
    "eslint-plugin-sort-destructure-keys": "2.0.0",
    "eslint-plugin-unicorn": "59.0.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.2.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "16.1.0",
    "micromatch": "4.0.8",
    "pinst": "3.0.0",
    "prettier": "3.5.3",
    "semantic-release": "24.2.5",
    "sort-package-json": "3.2.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.0"
  },
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
