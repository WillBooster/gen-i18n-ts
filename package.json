{
  "name": "gen-i18n-ts",
  "version": "0.0.0-semantically-released",
  "description": "A CLI tool to generate a strictly-typed i18n object literal written in TypeScript from JSON files.",
  "keywords": [
    "TypeScript",
    "i18n",
    "internationalization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/gen-i18n-ts.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "bin": "./bin/index.js",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "build-ts app",
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "prepare": "lefthook install || true",
    "start": "bun src/index.ts --",
    "start-prod": "bun run build && bun run gen-i18n-ts",
    "test": "bun wb test",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "dependencies": {
    "js-yaml": "4.3.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/helper-plugin-utils": "7.29.7",
    "@babel/node": "7.29.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-numeric-separator": "7.18.6",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.9.5",
    "@types/yargs": "17.0.35",
    "@willbooster/babel-configs": "2.5.1",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "@willbooster/wb": "15.3.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "build-ts": "19.0.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "semantic-release": "25.0.7",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
