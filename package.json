{
  "name": "gen-i18n-ts",
  "version": "0.0.0-semantically-released",
  "description": "A CLI tool to generate a strictly-typed i18n object literal written in TypeScript from JSON files.",
  "keywords": [
    "TypeScript",
    "i18n",
    "internationalization"
  ],
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/gen-i18n-ts.git"
  },
  "bin": "./bin/index.js",
  "files": [
    "bin/",
    "dist/"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "build-ts app",
    "check-all-for-ai": "yarn check-for-ai && yarn test",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null 2> /dev/null || true && yarn lint-fix --quiet",
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn format-code && yarn prettify",
    "format-code": "oxfmt --write --no-error-on-unmatched-pattern .",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint-fix": "yarn lint --fix",
    "prepare": "lefthook install || true",
    "prettify": "prettier --cache --color --no-error-on-unmatched-pattern --write \"**/{.*/,}*.{java}\" \"!**/test{-,/}fixtures/**\" || true",
    "start": "build-ts run src/index.ts --",
    "start-prod": "yarn build && yarn gen-i18n-ts",
    "test": "yarn vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "js-yaml": "4.1.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/helper-plugin-utils": "7.28.6",
    "@babel/node": "7.29.0",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-numeric-separator": "7.18.6",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "7.28.5",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.6.0",
    "@types/yargs": "17.0.35",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@willbooster/babel-configs": "2.5.1",
    "@willbooster/oxfmt-config": "1.2.1",
    "@willbooster/oxlint-config": "1.4.4",
    "@willbooster/prettier-config": "10.4.0",
    "babel-plugin-transform-remove-console": "6.9.4",
    "build-ts": "17.1.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.5",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.8.2",
    "prettier-plugin-java": "2.8.1",
    "semantic-release": "25.0.3",
    "sort-package-json": "3.6.1",
    "vitest": "4.1.4"
  },
  "prettier": "@willbooster/prettier-config",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.14.1"
}
